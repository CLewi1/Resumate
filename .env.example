# --- AI Tailoring provider ---
# Which provider to use for resume tailoring. Default: anthropic
# Supported values: anthropic, openai, openrouter, ollama, google
TAILOR_PROVIDER=anthropic

# Which model to use. If unset, a sensible default is chosen per provider:
#   anthropic   → claude-sonnet-4-6
#   openai      → gpt-4o
#   openrouter  → openai/gpt-4o-mini
#   ollama      → llama3.2
#   google      → gemini-2.0-flash
# TAILOR_MODEL=

# --- Provider API keys (set only the one matching TAILOR_PROVIDER) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Ollama runs locally — no API key needed.
# Override the base URL if Ollama is not on the default port:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- PDF generation (optional) ---
# API key for taxapi.ovh PDF generation. App works without it — PDF preview is disabled.
TEXAPI_KEY=
